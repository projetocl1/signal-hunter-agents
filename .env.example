# ─────────────────────────────────────────────────────────────
# signal-hunter-agents — variáveis de ambiente
# Copia este ficheiro para .env e preenche os valores reais.
# NENHUM destes valores é partilhado com pharma-intel-agents.
# ─────────────────────────────────────────────────────────────

# Chave da Claude API (classificação + navegação de fontes via web search)
ANTHROPIC_API_KEY=sk-ant-...

# Token de acesso pessoal do Airtable (scope: data.records:read + data.records:write)
AIRTABLE_TOKEN=pat...

# ID da BASE DEDICADA do Airtable para catalisadores (NUNCA a base do pharma-intel)
AIRTABLE_BASE_ID=app...

# (Opcional) Nome da tabela no Airtable. Default: catalyst_signals
AIRTABLE_TABLE=catalyst_signals

# (Opcional) Modelo Claude a usar. Default: claude-opus-4-8
CLAUDE_MODEL=claude-opus-4-8
